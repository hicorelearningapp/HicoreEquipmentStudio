<Window x:Class="HicoreEquipmentStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:view="clr-namespace:HicoreEquipmentStudio.View"
        xmlns:layout="clr-namespace:HicoreEquipmentStudio.View.Variable"
        xmlns:vm="clr-namespace:HicoreEquipmentStudio.ViewModel.Variable"

        mc:Ignorable="d"
        Title="Equipment Studio"
        WindowState="Maximized">

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:VariableViewModel}">
            <layout:VariableMainView/>
        </DataTemplate>

        <!--<DataTemplate DataType="{x:Type vm:AlarmViewModel}">
            <layout:Alarm/>
        </DataTemplate>-->

    </Window.Resources>

    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- COLUMNS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TOP EQUIPMENT INFO -->
        <view:EquipmentInformation Grid.Row="0"
                                   Grid.ColumnSpan="2"/>

        <!-- LEFT MENU -->
        <view:ConfigurationControl Grid.Row="1"
                                   Grid.Column="0"/>

        <!-- DYNAMIC CONTENT -->
        <ContentControl Grid.Row="1"
                        Grid.Column="1"
                        Content="{Binding CurrentViewModel}"/>

    </Grid>

</Window>