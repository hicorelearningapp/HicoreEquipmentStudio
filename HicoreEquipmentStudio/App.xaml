<Application x:Class="HiCore.EquipmentFramework.Config.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:layout="clr-namespace:HiCore.EquipmentFramework.Config.View.Variable"
             xmlns:alarm="clr-namespace:HiCore.EquipmentFramework.Config.View.Alarms"
             xmlns:event="clr-namespace:HiCore.EquipmentFramework.Config.View.Events"
             xmlns:recipe="clr-namespace:HiCore.EquipmentFramework.Config.View.Recipes"
             xmlns:command="clr-namespace:HiCore.EquipmentFramework.Config.View.Commands"
             xmlns:mapping="clr-namespace:HiCore.EquipmentFramework.Config.View.Mapping"


             xmlns:vm="clr-namespace:HiCore.EquipmentFramework.Config.ViewModel.Variable"
             xmlns:vms="clr-namespace:HiCore.EquipmentFramework.Config.ViewModel.Alarms"
             xmlns:vme="clr-namespace:HiCore.EquipmentFramework.Config.ViewModel.Events"
             xmlns:vmr="clr-namespace:HiCore.EquipmentFramework.Config.ViewModel.Recipes"
             xmlns:vmc="clr-namespace:HiCore.EquipmentFramework.Config.ViewModel.Commands"
             xmlns:vmm="clr-namespace:HiCore.EquipmentFramework.Config.ViewModel.Mapping"

             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <!-- ============================= -->
        <!-- Data Templates -->
        <!-- ============================= -->

        <DataTemplate DataType="{x:Type vm:VariableViewModel}">
            <layout:VariableMainView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vms:AlarmViewModel}">
            <alarm:AlarmMainView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vme:EventViewModel}">
            <event:EventMainView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmr:RecipeViewModel}">
            <recipe:RecipeMainView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmc:CommandViewModel}">
            <command:CommandMainView/>
        </DataTemplate>

        <!--<DataTemplate DataType="{x:Type vmm:MappingViewModel}">
            <mapping:SVIDMappingControl/>
        </DataTemplate>-->

        <!-- ============================= -->
        <!-- Menu Button Style -->
        <!-- ============================= -->

        <Style x:Key="MenuButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="40"/>

            <Setter Property="Margin"
                    Value="4"/>

            <Setter Property="Padding"
                    Value="10,0"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#F3F7FD"/>

                </Trigger>

            </Style.Triggers>

        </Style>

        <!-- ============================= -->
        <!-- Selected Menu Style -->
        <!-- ============================= -->

        <Style x:Key="SelectedMenuButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MenuButtonStyle}">

            <Setter Property="Background"
                    Value="#1565C0"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

        </Style>


        <Style x:Key="ToolbarButtonStyle"
       TargetType="Button">

            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="3">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="border"
                                Property="Background"
                                Value="#F5F9FF"/>

                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="#2F75B5"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="border"
                                Property="Background"
                                Value="#DCEBFF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="ToolbarSeparatorStyle"
        TargetType="Border">

            <Setter Property="Width"
            Value="1"/>

            <Setter Property="Background"
            Value="#D9D9D9"/>

            <Setter Property="Margin"
            Value="4,4"/>

        </Style>

        <Style x:Key="ToolbarSearchBoxStyle"
       TargetType="TextBox">

            <Setter Property="Height"
            Value="28"/>

            <Setter Property="Width"
            Value="220"/>

            <Setter Property="BorderBrush"
            Value="#D9D9D9"/>

            <Setter Property="BorderThickness"
            Value="1"/>

            <Setter Property="Padding"
            Value="8,0"/>
        </Style>




        <!-- ========================================= -->
        <!-- Common DataGrid -->
        <!-- ========================================= -->

        <Style x:Key="EquipmentDataGridStyle"
       TargetType="DataGrid">

            <Setter Property="AutoGenerateColumns"
            Value="False"/>

            <Setter Property="CanUserAddRows"
            Value="False"/>

            <Setter Property="CanUserDeleteRows"
            Value="False"/>

            <Setter Property="CanUserResizeRows"
            Value="False"/>

            <Setter Property="HeadersVisibility"
            Value="Column"/>

            <Setter Property="GridLinesVisibility"
            Value="Horizontal"/>

            <Setter Property="RowHeight"
            Value="28"/>

            <Setter Property="ColumnHeaderHeight"
            Value="32"/>

            <Setter Property="FontSize"
            Value="12"/>

            <Setter Property="BorderThickness"
            Value="1"/>

            <Setter Property="BorderBrush"
            Value="#D9D9D9"/>

        </Style>

        <Style x:Key="EquipmentDataGridHeaderStyle"
       TargetType="DataGridColumnHeader">

            <Setter Property="Background"
            Value="#F8F8F8"/>

            <Setter Property="Foreground"
            Value="#333"/>

            <Setter Property="FontWeight"
            Value="SemiBold"/>

            <Setter Property="Padding"
            Value="10,0"/>

            <Setter Property="BorderBrush"
            Value="#E2E2E2"/>

            <Setter Property="BorderThickness"
            Value="0,0,1,1"/>

        </Style>

        <Style x:Key="EquipmentDataGridRowStyle"
       TargetType="DataGridRow">

            <Setter Property="Height"
            Value="28"/>

            <Style.Triggers>

                <Trigger Property="IsSelected"
                 Value="True">

                    <Setter Property="Background"
                    Value="#D9E8FB"/>

                    <Setter Property="Foreground"
                    Value="Black"/>

                </Trigger>

            </Style.Triggers>

        </Style>

        <Style x:Key="EquipmentDataGridCellStyle"
       TargetType="DataGridCell">

            <Setter Property="Padding"
            Value="8,0"/>

            <Setter Property="BorderBrush"
            Value="#E8E8E8"/>

            <Setter Property="BorderThickness"
            Value="0,0,1,1"/>

            <Setter Property="VerticalContentAlignment"
            Value="Center"/>

        </Style>

        <Style x:Key="EditorTextBoxStyle"
       TargetType="TextBox">

            <Setter Property="Height"
            Value="24"/>

            <Setter Property="VerticalContentAlignment"
            Value="Center"/>

            <Setter Property="Padding"
            Value="4,0"/>

            <Setter Property="BorderBrush"
            Value="#D0D0D0"/>

            <Setter Property="BorderThickness"
            Value="1"/>

            <Setter Property="Margin"
            Value="0,2"/>
        </Style>

        <Style x:Key="EditorComboBoxStyle"
       TargetType="ComboBox">

            <Setter Property="Height"
            Value="24"/>

            <Setter Property="VerticalContentAlignment"
            Value="Center"/>

            <Setter Property="Margin"
            Value="0,2"/>
        </Style>

        <Style x:Key="EditorLabelStyle"
       TargetType="TextBlock">

            <Setter Property="VerticalAlignment"
            Value="Center"/>

            <Setter Property="FontSize"
            Value="12"/>

            <Setter Property="Foreground"
            Value="#333333"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
       TargetType="Button">

            <Setter Property="Height"
            Value="30"/>

            <Setter Property="MinWidth"
            Value="110"/>

            <Setter Property="Margin"
            Value="0,0,10,0"/>

            <Setter Property="Background"
            Value="#EAF2FD"/>

            <Setter Property="BorderBrush"
            Value="#8BB8F3"/>

            <Setter Property="BorderThickness"
            Value="1"/>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle"
       TargetType="Button">

            <Setter Property="Height"
            Value="24"/>
            
            <Setter Property="Margin"
            Value="0,0,10,0"/>
        </Style>


        <Style x:Key="DisabledActionButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource SecondaryActionButtonStyle}">

            <Setter Property="IsEnabled"
            Value="False"/>
        </Style>


        <Style x:Key="DetailsGroupBoxStyle"
       TargetType="GroupBox">

            <Setter Property="Padding"
            Value="5"/>

            <Setter Property="BorderBrush"
            Value="#D9D9D9"/>

            <Setter Property="BorderThickness"
            Value="1"/>

            <Setter Property="FontWeight"
            Value="SemiBold"/>

            <Setter Property="Foreground"
            Value="#2F75B5"/>
        </Style>



        <Style x:Key="PreviewValueStyle"
       TargetType="TextBlock">

            <Setter Property="VerticalAlignment"
            Value="Center"/>

            <Setter Property="FontSize"
            Value="12"/>

            <Setter Property="Foreground"
            Value="#333333"/>
            
            
            

        </Style>



        <Style x:Key="SectionHeaderBorderStyle"
       TargetType="Border">

            <Setter Property="Background"
            Value="#FAFAFA"/>

            <Setter Property="BorderBrush"
            Value="#E5E5E5"/>

            <Setter Property="BorderThickness"
            Value="0,0,0,1"/>

        </Style>

        <Style x:Key="SectionHeaderTextStyle"
       TargetType="TextBlock">

            <Setter Property="Margin"
            Value="12,0"/>

            <Setter Property="VerticalAlignment"
            Value="Center"/>

            <Setter Property="FontSize"
            Value="14"/>

            <Setter Property="FontWeight"
            Value="SemiBold"/>

            <Setter Property="Foreground"
            Value="#2F75B5"/>

        </Style>

        <!-- Primary Button -->

        <Style x:Key="PrimaryButtonStyle"
       TargetType="Button">

            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,0"/>

            <Setter Property="Background" Value="#EAF3FF"/>
            <Setter Property="BorderBrush" Value="#6EA8FE"/>
            <Setter Property="BorderThickness" Value="1"/>

        </Style>

        <!-- Secondary Button -->

        <Style x:Key="SecondaryButtonStyle"
       TargetType="Button">

            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,0"/>

            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="1"/>

        </Style>

    </Application.Resources>

</Application>