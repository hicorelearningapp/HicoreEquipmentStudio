<UserControl x:Class="HicoreEquipmentStudio.View.Alarms.AlarmPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Alarm Test / Preview">

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel>

                <TextBlock Text="Last Change Time:"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding LastChangeTime}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Current Value:"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding CurrentValue}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Alarm Status:"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding AlarmStatus}"
                           Foreground="Green"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Active:"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding Active}"
                           Foreground="Green"
                           FontWeight="Bold"/>

            </StackPanel>

            <DataGrid Grid.Row="1"
                      Margin="0,10,0,0"
                      AutoGenerateColumns="False"
                      ItemsSource="{Binding AlarmHistory}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Time"
                                        Binding="{Binding Time}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Value"
                                        Binding="{Binding Value}"
                                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

    </GroupBox>

</UserControl>