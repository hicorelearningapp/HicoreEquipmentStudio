<UserControl x:Class="HicoreEquipmentStudio.View.Alarms.AlarmToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HicoreEquipmentStudio.Controls">

    <controls:CommonToolbarControl
    AddCommand="{Binding AddAlarmCommand}"
    EditCommand="{Binding EditAlarmCommand}"
    DeleteCommand="{Binding DeleteAlarmCommand}"
    ImportCommand="{Binding ImportAlarmCommand}"
    ExportCommand="{Binding ExportAlarmCommand}"
    ValidateCommand="{Binding ValidateAlarmCommand}" />

</UserControl>