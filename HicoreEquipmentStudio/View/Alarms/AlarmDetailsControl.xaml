<UserControl x:Class="HicoreEquipmentStudio.View.Alarms.AlarmDetailsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Alarm Details">

        <Grid Margin="15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <TextBlock Text="ALID:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding SelectedAlarm.ALID}"/>

            <TextBlock Grid.Column="3" Text="Category:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="4"/>

            <TextBlock Grid.Row="1" Text="Alarm Name:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding SelectedAlarm.AlarmName}"/>

            <TextBlock Grid.Row="1" Grid.Column="3"
                       Text="Enabled:"
                       VerticalAlignment="Center"/>

            <CheckBox Grid.Row="1"
                      Grid.Column="4"
                      IsChecked="{Binding SelectedAlarm.Enabled}"
                      VerticalAlignment="Center"/>

            <TextBlock Grid.Row="2" Text="Description:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding SelectedAlarm.Description}"/>

            <TextBlock Grid.Row="2" Grid.Column="3"
                       Text="Latch:"
                       VerticalAlignment="Center"/>

            <ComboBox Grid.Row="2" Grid.Column="4"/>

            <TextBlock Grid.Row="3" Text="Source Type:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="3" Grid.Column="1"/>

            <TextBlock Grid.Row="3" Grid.Column="3"
                       Text="Reset Type:"
                       VerticalAlignment="Center"/>

            <ComboBox Grid.Row="3" Grid.Column="4"/>

            <TextBlock Grid.Row="4" Text="Address / Source:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     Text="{Binding SelectedAlarm.Address}"/>

            <TextBlock Grid.Row="4" Grid.Column="3"
                       Text="Debounce:"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Row="4" Grid.Column="4"/>

            <TextBlock Grid.Row="5" Text="Condition / Value:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="5" Grid.Column="1"
                     Text="{Binding SelectedAlarm.Condition}"/>

            <TextBlock Grid.Row="5" Grid.Column="3"
                       Text="Clear Condition:"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Row="5" Grid.Column="4"/>

            <TextBlock Grid.Row="6" Text="Severity:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="6" Grid.Column="1"/>

            <TextBlock Grid.Row="6" Grid.Column="3"
                       Text="Priority:"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Row="6" Grid.Column="4"/>

            <StackPanel Grid.Row="7"
                        Grid.ColumnSpan="5"
                        Orientation="Horizontal"
                        Margin="0,10,0,0">

                <Button Content="💾 Save Alarm"
                        Width="120"
                        Margin="0,0,10,0"/>

                <Button Content="Cancel"
                        Width="100"
                        Margin="0,0,10,0"/>

                <Button Content="▶ Test Alarm"
                        Width="120"
                        Margin="0,0,10,0"/>

                <Button Content="⚡ Simulate"
                        Width="120"/>
            </StackPanel>

        </Grid>

    </GroupBox>

</UserControl>