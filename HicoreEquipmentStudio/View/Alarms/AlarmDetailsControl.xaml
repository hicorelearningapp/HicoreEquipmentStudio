<UserControl x:Class="HicoreEquipmentStudio.View.Alarms.AlarmDetailsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Alarm Details"
              Style="{StaticResource DetailsGroupBoxStyle}">

        <Grid Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <!-- Row 1 -->

            <TextBlock Text="ALID:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Column="1"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingAlarm.ALID,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Column="3"
                       Text="Category:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Column="4"
                      Style="{StaticResource EditorComboBoxStyle}"
                      SelectedItem="{Binding EditingAlarm.Category}"/>

            <!-- Row 2 -->

            <TextBlock Grid.Row="1"
                       Text="Alarm Name:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingAlarm.AlarmName,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="3"
                       Text="Enabled:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <CheckBox Grid.Row="1"
                      Grid.Column="4"
                      VerticalAlignment="Center"
                      IsChecked="{Binding EditingAlarm.Enabled}"/>

            <!-- Row 3 -->

            <TextBlock Grid.Row="2"
                       Text="Description:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="2"
                     Grid.Column="1"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingAlarm.Description,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="3"
                       Text="Latch:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Row="2"
                      Grid.Column="4"
                      Style="{StaticResource EditorComboBoxStyle}"/>

            <!-- Row 4 -->

            <TextBlock Grid.Row="3"
                       Text="Source Type:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Row="3"
                      Grid.Column="1"
                      Style="{StaticResource EditorComboBoxStyle}"
                      SelectedItem="{Binding EditingAlarm.SourceType}"/>

            <TextBlock Grid.Row="3"
                       Grid.Column="3"
                       Text="Reset Type:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Row="3"
                      Grid.Column="4"
                      Style="{StaticResource EditorComboBoxStyle}"/>

            <!-- Row 5 -->

            <TextBlock Grid.Row="4"
                       Text="Address / Source:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <Grid Grid.Row="4"
                  Grid.Column="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EditingAlarm.Address,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="2"
                        Content="Browse"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>

            </Grid>

            <TextBlock Grid.Row="4"
                       Grid.Column="3"
                       Text="Debounce (ms):"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="4"
                     Grid.Column="4"
                     Style="{StaticResource EditorTextBoxStyle}"/>

            <!-- Row 6 -->

            <TextBlock Grid.Row="5"
                       Text="Condition / Value:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <Grid Grid.Row="5"
                  Grid.Column="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          Style="{StaticResource EditorComboBoxStyle}"/>

                <TextBox Grid.Column="2"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EditingAlarm.Condition,
                                        UpdateSourceTrigger=PropertyChanged}"/>

            </Grid>

            <TextBlock Grid.Row="5"
                       Grid.Column="3"
                       Text="Clear Condition:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="5"
                     Grid.Column="4"
                     Style="{StaticResource EditorTextBoxStyle}"/>

            <!-- Row 7 -->

            <TextBlock Grid.Row="6"
                       Text="Severity:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Row="6"
                      Grid.Column="1"
                      Style="{StaticResource EditorComboBoxStyle}"
                      SelectedItem="{Binding EditingAlarm.Severity}"/>

            <TextBlock Grid.Row="6"
                       Grid.Column="3"
                       Text="Priority:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="6"
                     Grid.Column="4"
                     Style="{StaticResource EditorTextBoxStyle}"/>

            <!-- Buttons -->

            <StackPanel Grid.Row="7"
                        Grid.ColumnSpan="5"
                        Orientation="Horizontal"
                        Margin="0,10,0,0">

                <Button Content="💾 Save Alarm"
                        Command="{Binding SaveAlarmCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>

                <Button Content="⊘ Cancel"
                        Command="{Binding CancelAlarmCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>

            </StackPanel>

        </Grid>

    </GroupBox>

</UserControl>