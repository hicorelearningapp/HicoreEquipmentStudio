<UserControl x:Class="HicoreEquipmentStudio.View.Variable.VariableGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HicoreEquipmentStudio.View.Variable"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DataGrid Margin="10"
              AutoGenerateColumns="False"
              HeadersVisibility="Column"
              CanUserAddRows="False"
              SelectionMode="Single"
              ItemsSource="{Binding Variables}"
              SelectedItem="{Binding SelectedVariable}">

        <DataGrid.Columns>

            <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}"
                                Width="150"/>

            <DataGridTextColumn Header="Address"
                                Binding="{Binding Address}"
                                Width="120"/>

            <DataGridTextColumn Header="Data Type"
                                Binding="{Binding DataType}"
                                Width="120"/>

            <DataGridTextColumn Header="Category"
                                Binding="{Binding Category}"
                                Width="120"/>

            <DataGridTextColumn Header="Access"
                                Binding="{Binding Access}"
                                Width="100"/>

            <DataGridTextColumn Header="Poll Interval"
                                Binding="{Binding PollInterval}"
                                Width="120"/>

            <DataGridTextColumn Header="SVID"
                                Binding="{Binding SVID}"
                                Width="100"/>

            <DataGridTextColumn Header="Units"
                                Binding="{Binding Units}"
                                Width="100"/>

            <DataGridTextColumn Header="Description"
                                Binding="{Binding Description}"
                                Width="*"/>

        </DataGrid.Columns>

    </DataGrid>
</UserControl>
