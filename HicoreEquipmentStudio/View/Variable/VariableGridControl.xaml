<UserControl x:Class="HiCore.EquipmentFramework.Config.View.Variable.VariableGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <DataGrid Margin="10"
              AutoGenerateColumns="False"
              ItemsSource="{Binding Variables}"
              SelectedItem="{Binding SelectedVariable}"
              Style="{StaticResource EquipmentDataGridStyle}"
              ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
              RowStyle="{StaticResource EquipmentDataGridRowStyle}"
              CellStyle="{StaticResource EquipmentDataGridCellStyle}">

        <DataGrid.Columns>

            <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}"
                                Width="140"/>

            <DataGridTextColumn Header="Address"
                                Binding="{Binding Address}"
                                Width="90"/>

            <DataGridTextColumn Header="Data Type"
                                Binding="{Binding DataType}"
                                Width="90"/>

            <DataGridTextColumn Header="Category"
                                Binding="{Binding Category}"
                                Width="100"/>

            <DataGridTextColumn Header="Access"
                                Binding="{Binding Access}"
                                Width="100"/>

            <DataGridTextColumn Header="Poll Interval (ms)"
                                Binding="{Binding PollInterval}"
                                Width="120"/>

            <DataGridTextColumn Header="SVID"
                                Binding="{Binding SVID}"
                                Width="80"/>

            <DataGridTextColumn Header="Units"
                                Binding="{Binding Units}"
                                Width="80"/>

            <DataGridTextColumn Header="Description"
                                Binding="{Binding Description}"
                                Width="*"/>

        </DataGrid.Columns>

    </DataGrid>

</UserControl>