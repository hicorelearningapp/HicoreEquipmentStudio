<UserControl x:Class="HicoreEquipmentStudio.View.Variable.VariableToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HicoreEquipmentStudio.Controls">

    <controls:CommonToolbarControl
    AddCommand="{Binding AddVariableCommand}"
    EditCommand="{Binding EditVariableCommand}"
    DeleteCommand="{Binding DeleteVariableCommand}"
    ImportCommand="{Binding ImportVariableCommand}"
    ExportCommand="{Binding ExportVariableCommand}"
    ValidateCommand="{Binding ValidateVariableCommand}" />

</UserControl>