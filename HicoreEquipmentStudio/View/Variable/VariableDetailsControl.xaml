<UserControl x:Class="HicoreEquipmentStudio.View.Variable.VariableDetailsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HicoreEquipmentStudio.View.Variable"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <GroupBox Header="Variable Details"
          Margin="0">

        <Grid Margin="5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Row 1 -->
            <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Name:"
                   VerticalAlignment="Center"/>

            <TextBox Grid.Row="0"
                 Grid.Column="1"
                 Height="28"
                 Text="{Binding SelectedVariable.Name}"/>

            <TextBlock Grid.Row="0"
                   Grid.Column="3"
                   Text="Access:"
                   VerticalAlignment="Center"/>

            <ComboBox Grid.Row="0"
                  Grid.Column="4"
                  Height="28"
                  SelectedItem="{Binding SelectedVariable.Access}"/>

            <!-- Row 2 -->
            <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Text="Description:"
                   VerticalAlignment="Center"/>

            <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Height="28"
                 Text="{Binding SelectedVariable.Description}"/>

            <TextBlock Grid.Row="1"
                   Grid.Column="3"
                   Text="Poll Interval:"
                   VerticalAlignment="Center"/>

            <TextBox Grid.Row="1"
                 Grid.Column="4"
                 Height="28"
                 Text="{Binding SelectedVariable.PollInterval}"/>

            <!-- Row 3 -->
            <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Address:"
                   VerticalAlignment="Center"/>

            <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Height="28"
                 Text="{Binding SelectedVariable.Address}"/>

            <TextBlock Grid.Row="2"
                   Grid.Column="3"
                   Text="Units:"
                   VerticalAlignment="Center"/>

            <TextBox Grid.Row="2"
                 Grid.Column="4"
                 Height="28"
                 Text="{Binding SelectedVariable.Units}"/>

            <!-- Row 4 -->
            <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Text="Data Type:"
                   VerticalAlignment="Center"/>

            <ComboBox Grid.Row="3"
                  Grid.Column="1"
                  Height="28"
                  SelectedItem="{Binding SelectedVariable.DataType}"/>

            <TextBlock Grid.Row="3"
                   Grid.Column="3"
                   Text="SVID:"
                   VerticalAlignment="Center"/>

            <TextBox Grid.Row="3"
                 Grid.Column="4"
                 Height="28"
                 Text="{Binding SelectedVariable.SVID}"/>

            <!-- Row 5 -->
            <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Text="Category:"
                   VerticalAlignment="Center"/>

            <ComboBox Grid.Row="4"
                  Grid.Column="1"
                  Height="28"
                  SelectedItem="{Binding SelectedVariable.Category}"/>

            <TextBlock Grid.Row="4"
                   Grid.Column="3"
                   Text="Default Value:"
                   VerticalAlignment="Center"/>

            <TextBox Grid.Row="4"
                 Grid.Column="4"
                 Height="28"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="5"
                    Orientation="Horizontal"
                    Margin="0,12,0,0">

                <Button Content="Save Variable"
                    Width="120"
                    Height="32"
                    Margin="0,0,8,0"/>

                <Button Content="Cancel"
                    Width="90"
                    Height="32"
                    Margin="0,0,8,0" Click="Button_Click"/>

                <Button Content="Test Read"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"/>

                <Button Content="Test Write"
                    Width="100"
                    Height="32"/>
            </StackPanel>

        </Grid>

    </GroupBox>
</UserControl>
