<UserControl x:Class="HicoreEquipmentStudio.View.Variable.VariableDetailsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Variable Details"
              Style="{StaticResource DetailsGroupBoxStyle}">

        <Grid Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <!-- Row 1 -->

            <TextBlock Text="Variable Name:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Column="1"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingVariable.Name,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Column="3"
                       Text="Access:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Column="4"
                      Style="{StaticResource EditorComboBoxStyle}"
                      SelectedItem="{Binding EditingVariable.Access}"/>

            <!-- Row 2 -->

            <TextBlock Grid.Row="1"
                       Text="Description:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingVariable.Description,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="3"
                       Text="Poll Interval:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="1"
                     Grid.Column="4"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingVariable.PollInterval,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Row 3 -->

            <TextBlock Grid.Row="2"
                       Text="Address:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <Grid Grid.Row="2"
                  Grid.Column="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EditingVariable.Address,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="2"
                        Content="Browse"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>

            </Grid>

            <TextBlock Grid.Row="2"
                       Grid.Column="3"
                       Text="Units:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="2"
                     Grid.Column="4"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingVariable.Units,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Row 4 -->

            <TextBlock Grid.Row="3"
                       Text="Data Type:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Row="3"
                      Grid.Column="1"
                      Style="{StaticResource EditorComboBoxStyle}"
                      SelectedItem="{Binding EditingVariable.DataType}"/>

            <TextBlock Grid.Row="3"
                       Grid.Column="3"
                       Text="SVID:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="3"
                     Grid.Column="4"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Text="{Binding EditingVariable.SVID,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Row 5 -->

            <TextBlock Grid.Row="4"
                       Text="Category:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <ComboBox Grid.Row="4"
                      Grid.Column="1"
                      Style="{StaticResource EditorComboBoxStyle}"
                      SelectedItem="{Binding EditingVariable.Category}"/>

            <TextBlock Grid.Row="4"
                       Grid.Column="3"
                       Text="Default Value:"
                       Style="{StaticResource EditorLabelStyle}"/>

            <TextBox Grid.Row="4"
                     Grid.Column="4"
                     Style="{StaticResource EditorTextBoxStyle}"/>

            <!-- Buttons -->

            <StackPanel Grid.Row="5"
                        Grid.ColumnSpan="5"
                        Orientation="Horizontal"
                        Margin="0,10,0,0">

                <Button Content="💾 Save Variable"
                        Command="{Binding SaveVariableCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>

                <Button Content="⊘ Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>

                <!--<Button Content="▶ Test Read"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>

                <Button Content="✎ Test Write"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>-->

            </StackPanel>

        </Grid>

    </GroupBox>

</UserControl>