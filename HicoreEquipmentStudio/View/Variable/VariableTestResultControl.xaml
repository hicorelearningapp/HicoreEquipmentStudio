<UserControl x:Class="HicoreEquipmentStudio.View.Variable.VariableTestResultControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HicoreEquipmentStudio.View.Variable"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <GroupBox Header="Test Result">

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel>

                <TextBlock Text="Last Read Time:"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding LastReadTime}"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Value:"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding CurrentValue}"
                           Foreground="Green"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Status:"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding Status}"
                           Foreground="Green"
                           FontWeight="Bold"/>

            </StackPanel>

            <DataGrid Grid.Row="1"
                      Margin="0,10,0,0"
                      AutoGenerateColumns="False"
                      ItemsSource="{Binding ReadHistory}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Time"
                                        Binding="{Binding Time}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Value"
                                        Binding="{Binding Value}"
                                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

    </GroupBox>
</UserControl>
