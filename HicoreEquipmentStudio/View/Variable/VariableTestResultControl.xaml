<UserControl x:Class="HiCore.EquipmentFramework.Config.View.Variable.VariableTestResultControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Variable Test / Preview"
              Style="{StaticResource DetailsGroupBoxStyle}">

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Summary -->

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Last Read Time:"
                           Style="{StaticResource EditorLabelStyle}"/>

                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding LastReadTime}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Text="Current Value:"
                           Style="{StaticResource EditorLabelStyle}"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding CurrentValue}"
                           Foreground="#2E7D32"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Text="Status:"
                           Style="{StaticResource EditorLabelStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding Status}"
                           Foreground="#2E7D32"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

            </Grid>

            <!-- Read History -->

            <Grid Grid.Row="2">

                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Read History"
                           Foreground="#2F75B5"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <DataGrid Grid.Row="1"
                          Margin="0,4,0,0"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding ReadHistory}"
                          Style="{StaticResource EquipmentDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
                          RowStyle="{StaticResource EquipmentDataGridRowStyle}"
                          CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Time"
                                            Binding="{Binding Time}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Value"
                                            Binding="{Binding Value}"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Grid>

    </GroupBox>

</UserControl>