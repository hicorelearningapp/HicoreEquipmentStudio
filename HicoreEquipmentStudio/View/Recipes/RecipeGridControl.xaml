<UserControl x:Class="HiCore.EquipmentFramework.Config.View.Recipes.RecipeGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HiCore.EquipmentFramework.Config.View.Recipes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <DataGrid
    Margin="10"
    AutoGenerateColumns="False"
    ItemsSource="{Binding Recipes}"
    SelectedItem="{Binding SelectedRecipe}"

    Style="{StaticResource EquipmentDataGridStyle}"
    ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
    RowStyle="{StaticResource EquipmentDataGridRowStyle}"
    CellStyle="{StaticResource EquipmentDataGridCellStyle}">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Recipe ID"
                            Binding="{Binding RecipeID}"
                            Width="*"/>

                <DataGridTextColumn Header="Recipe Name"
                            Binding="{Binding RecipeName}"
                            Width="*"/>

                <DataGridTextColumn Header="Description"
                            Binding="{Binding Description}"
                            Width="*"/>

                <DataGridTextColumn Header="Data Source Type"
                            Binding="{Binding DataSourceType}"
                            Width="*"/>

                <DataGridTextColumn Header="Address / File Path"
                            Binding="{Binding Address}"
                            Width="*"/>

                <DataGridTextColumn Header="Data Format"
                            Binding="{Binding DataFormat}"
                            Width="*"/>

                <DataGridTextColumn Header="Total Parameters"
                            Binding="{Binding ParameterCount}"
                            Width="*"/>

                <DataGridCheckBoxColumn Header="Enabled"
                                Binding="{Binding Enabled}"
                            Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</UserControl>
