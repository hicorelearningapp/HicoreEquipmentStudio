<UserControl x:Class="HicoreEquipmentStudio.View.Recipes.RecipeToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HicoreEquipmentStudio.Controls">

    <controls:CommonToolbarControl
    AddCommand="{Binding AddRecipeCommand}"
    EditCommand="{Binding EditRecipeCommand}"
    DeleteCommand="{Binding DeleteRecipeCommand}"
    ImportCommand="{Binding ImportRecipeCommand}"
    ExportCommand="{Binding ExportRecipeCommand}"
    ValidateCommand="{Binding ValidateRecipeCommand}" />

</UserControl>