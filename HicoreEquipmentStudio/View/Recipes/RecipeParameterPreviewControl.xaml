<UserControl x:Class="HicoreEquipmentStudio.View.Recipes.RecipeParameterPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Recipe Parameters (Preview)"
              Style="{StaticResource DetailsGroupBoxStyle}">

        <Grid Margin="8">

            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="70"
                        Height="26"
                        Content="⟳ Refresh"/>

                <TextBox Grid.Column="3"
         Width="180"
         Height="26"
         HorizontalAlignment="Right"
         Style="{StaticResource ToolbarSearchBoxStyle}" />

            </Grid>

            <!-- Parameters Grid -->

            <DataGrid Grid.Row="1"
                      Margin="0,8,0,0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      ItemsSource="{Binding Parameters}"

                      Style="{StaticResource EquipmentDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
                      RowStyle="{StaticResource EquipmentDataGridRowStyle}"
                      CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Parameter Index"
                    Binding="{Binding Index}"
                    Width="*"/>

                    <DataGridTextColumn Header="Parameter Name"
                    Binding="{Binding ParameterName}"
                    Width="2*"/>

                    <DataGridTextColumn Header="Address"
                    Binding="{Binding Address}"
                    Width="*"/>

                    <DataGridTextColumn Header="Data Type"
                    Binding="{Binding DataType}"
                    Width="*"/>

                    <DataGridTextColumn Header="Default Value"
                    Binding="{Binding DefaultValue}"
                    Width="*"/>

                    <DataGridTextColumn Header="Units"
                    Binding="{Binding Units}"
                    Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

    </GroupBox>

</UserControl>