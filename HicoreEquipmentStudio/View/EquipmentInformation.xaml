<UserControl x:Class="HicoreEquipmentStudio.View.EquipmentInformation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Equipment Information"
          Margin="5"
          Style="{StaticResource DetailsGroupBoxStyle}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content -->

            <Grid Grid.Row="1"
                  Margin="0,6,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 1 -->

                <Grid Grid.Column="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Equipment ID:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Column="1"
                             Height="24"
                             Text="FC001"/>

                    <TextBlock Grid.Row="1"
                               Text="Model:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Height="24"
                             Text="WEFG-3005A"/>

                    <TextBlock Grid.Row="2"
                               Text="Port:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Height="24"
                             Text="502"/>

                </Grid>

                <!-- Column 2 -->

                <Grid Grid.Column="1"
                      Margin="10,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Equipment Name:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Column="1"
                             Height="24"
                             Text="Flux Cleaner"/>

                    <TextBlock Grid.Row="1"
                               Text="Protocol:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              Height="24">

                        <ComboBoxItem Content="Modbus TCP"/>

                    </ComboBox>

                    <TextBlock Grid.Row="2"
                               Text="Timeout (ms):"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Height="24"
                             Text="3000"/>

                </Grid>

                <!-- Column 3 -->

                <Grid Grid.Column="2"
                      Margin="10,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Vendor:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Column="1"
                             Height="24"
                             Text="World Engineering"/>

                    <TextBlock Grid.Row="1"
                               Text="IP Address:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Height="24"
                             Text="192.168.1.100"/>

                    <TextBlock Grid.Row="2"
                               Text="Reconnect:"
                               Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Height="24"
                             Text="5"/>

                </Grid>

                <!-- Connection Status -->

                <GroupBox Grid.Column="3"
                          Margin="10,0,0,0"
                          Header="Connection Status"
                          Style="{StaticResource DetailsGroupBoxStyle}">

                    <Grid Margin="5">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,5">

                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#28A745"
                                         VerticalAlignment="Center"/>

                                <TextBlock Text="Connected"
                                           Margin="6,0,0,0"
                                           Foreground="#28A745"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                            <Button Content="Test Connection"
                                    Width="110"
                                    Height="26"
                                    Margin="0,8,0,0" HorizontalAlignment="Left"/>

                        </StackPanel>

                        <Image Grid.Column="1"
                               Source="/Images/ConnectionDiagram.jpg"
                               Width="150"
                               Height="70"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    </Grid>

                </GroupBox>

            </Grid>

        </Grid>

    </GroupBox>

</UserControl>