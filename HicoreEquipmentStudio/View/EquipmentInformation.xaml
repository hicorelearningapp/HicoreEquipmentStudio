<UserControl x:Class="HicoreEquipmentStudio.View.EquipmentInformation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="1200">

    <Border BorderBrush="#D9D9D9"
            BorderThickness="1"
            Margin="5"
            Padding="10">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="Equipment Information"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#2F75B5"
                       Margin="0,0,0,12"/>

            <!-- Main Content -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ========================================= -->
                <!-- Column 1 -->
                <!-- ========================================= -->
                <Grid Grid.Column="0" Margin="0,0,15,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Equipment ID:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,10"/>

                    <TextBox Grid.Column="1"
                             Text="FC001"
                             Margin="0,0,0,10"
                             Height="28"/>

                    <TextBlock Grid.Row="1"
                               Text="Model:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,10"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="WEFG-3005A"
                             Margin="0,0,0,10"
                             Height="28"/>

                    <TextBlock Grid.Row="2"
                               Text="Port:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="502"
                             Height="28"/>

                </Grid>

                <!-- ========================================= -->
                <!-- Column 2 -->
                <!-- ========================================= -->
                <Grid Grid.Column="1" Margin="0,0,15,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Equipment Name:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,10"/>

                    <TextBox Grid.Column="1"
                             Text="Flux Cleaner"
                             Margin="0,0,0,10"
                             Height="28"/>

                    <TextBlock Grid.Row="1"
                               Text="Protocol:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,10"/>

                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              Height="28"
                              Margin="0,0,0,10">

                        <ComboBoxItem Content="Modbus TCP"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2"
                               Text="Timeout (ms):"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="3000"
                             Height="28"/>

                </Grid>

                <!-- ========================================= -->
                <!-- Column 3 -->
                <!-- ========================================= -->
                <Grid Grid.Column="2" Margin="0,0,15,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Vendor:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,10"/>

                    <TextBox Grid.Column="1"
                             Text="World Engineering"
                             Margin="0,0,0,10"
                             Height="28"/>

                    <TextBlock Grid.Row="1"
                               Text="IP Address:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,10"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="192.168.1.100"
                             Margin="0,0,0,10"
                             Height="28"/>

                    <TextBlock Grid.Row="2"
                               Text="Reconnect:"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="5"
                             Height="28"/>

                </Grid>

                <!-- ========================================= -->
                <!-- Column 4 : Connection Status -->
                <!-- ========================================= -->
                <Grid Grid.Column="3" Margin="10,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side -->
                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Connection Status"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#2F75B5"
                   Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,15">

                            <Ellipse Width="14"
                     Height="14"
                     Fill="#28A745"
                     VerticalAlignment="Center"/>

                            <TextBlock Text="Connected"
                       Margin="8,0,0,0"
                       Foreground="#28A745"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

                        </StackPanel>

                        <Button Content="Test Connection"
                Width="130"
                Height="32"/>

                    </StackPanel>

                    <!-- Right Side -->
                    <Grid Grid.Column="1">

                        <Image Source="/Images/ConnectionDiagram.jpg"
               Width="140"
               Height="80"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

                    </Grid>

                </Grid>

            </Grid>

        </Grid>

    </Border>

</UserControl>