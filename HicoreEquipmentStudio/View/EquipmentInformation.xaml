<UserControl x:Class="HicoreEquipmentStudio.View.EquipmentInformation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Equipment Information"
          Margin="5"
          Style="{StaticResource DetailsGroupBoxStyle}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content -->

            <Grid Grid.Row="1"
                  Margin="0,6,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ========================================= -->
                <!-- COLUMN 1 -->
                <!-- ========================================= -->

                <Grid Grid.Column="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Equipment ID:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.EquipmentId,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1"
                           Text="Model:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.Model,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2"
                           Text="Port:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.Port,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                </Grid>

                <!-- ========================================= -->
                <!-- COLUMN 2 -->
                <!-- ========================================= -->

                <Grid Grid.Column="1"
                  Margin="10,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Equipment Name:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.EquipmentName,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1"
                           Text="Protocol:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <ComboBox Grid.Row="1"
                          Grid.Column="1"
                          Style="{StaticResource EditorComboBoxStyle}"
                          SelectedItem="{Binding EquipmentInfo.Protocol}">

                        <ComboBoxItem Content="Modbus TCP"/>
                        <ComboBoxItem Content="Modbus RTU"/>
                        <ComboBoxItem Content="SECS/GEM"/>
                        <ComboBoxItem Content="OPC UA"/>
                        <ComboBoxItem Content="MQTT"/>

                    </ComboBox>

                    <TextBlock Grid.Row="2"
                           Text="Timeout (ms):"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.Timeout,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                </Grid>

                <!-- ========================================= -->
                <!-- COLUMN 3 -->
                <!-- ========================================= -->

                <Grid Grid.Column="2"
                  Margin="10,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Vendor:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.Vendor,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1"
                           Text="IP Address:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.IPAddress,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2"
                           Text="Reconnect:"
                           Style="{StaticResource EditorLabelStyle}"/>

                    <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Text="{Binding EquipmentInfo.ReconnectInterval,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                </Grid>

                <!-- Connection Status -->

                <!-- ========================================= -->
                <!-- CONNECTION STATUS -->
                <!-- ========================================= -->

                <GroupBox Grid.Column="3"
                      Margin="10,0,0,0"
                      Header="Connection Status"
                      Style="{StaticResource DetailsGroupBoxStyle}">

                    <Grid Margin="8">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <StackPanel Orientation="Horizontal"
                                    Margin="0,5">

                                <Ellipse Width="10"
                                     Height="10"
                                     Fill="#28A745"
                                     VerticalAlignment="Center"/>

                                <TextBlock Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#28A745"
                                       Text="Connected"/>

                            </StackPanel>

                            <Button Content="Test Connection"
                                Width="120"
                                Height="28"
                                Margin="0,10,0,0"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding }"
                                 />

                        </StackPanel>

                        <Image Grid.Column="1"
                           Width="140"
                           Height="75"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Source="/Images/ConnectionDiagram.jpg"/>

                    </Grid>

                </GroupBox>

            </Grid>

        </Grid>

    </GroupBox>

</UserControl>