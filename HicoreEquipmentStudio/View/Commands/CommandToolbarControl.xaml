<UserControl x:Class="HicoreEquipmentStudio.View.Commands.CommandToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HicoreEquipmentStudio.Controls">

    <controls:CommonToolbarControl
    AddCommand="{Binding AddCommandCommand}"
    EditCommand="{Binding EditCommandCommand}"
    DeleteCommand="{Binding DeleteCommandCommand}"
    ImportCommand="{Binding ImportCommandCommand}"
    ExportCommand="{Binding ExportCommandCommand}"
    ValidateCommand="{Binding ValidateCommandCommand}" />

</UserControl>