<UserControl x:Class="HicoreEquipmentStudio.View.Commands.CommandToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="#D9D9D9"
            BorderThickness="0,0,0,1"
            Background="White">

        <Grid Height="36">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="+ Add" Style="{StaticResource ToolbarButtonStyle}"/>
            <Border Grid.Column="1" Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="2" Content="✎ Edit" Style="{StaticResource ToolbarButtonStyle}"/>
            <Border Grid.Column="3" Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="4" Content="✕ Delete" Style="{StaticResource ToolbarButtonStyle}"/>
            <Border Grid.Column="5" Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="6" Content="⭳ Import" Style="{StaticResource ToolbarButtonStyle}"/>
            <Border Grid.Column="7" Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="8" Content="⭱ Export" Style="{StaticResource ToolbarButtonStyle}"/>
            <Border Grid.Column="9" Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="10" Content="✔ Validate" Style="{StaticResource ToolbarButtonStyle}"/>

            <TextBox Grid.Column="12"
                     Margin="5,4"
                     Style="{StaticResource ToolbarSearchBoxStyle}"
                     Text="{Binding SearchText}"/>

        </Grid>

    </Border>

</UserControl>