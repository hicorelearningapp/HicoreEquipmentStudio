<UserControl x:Class="HiCore.EquipmentFramework.Config.View.Commands.CommandGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataGrid Margin="0"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              HeadersVisibility="Column"
              ItemsSource="{Binding Commands}"
              SelectedItem="{Binding SelectedCommand}"

              Style="{StaticResource EquipmentDataGridStyle}"
              ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
              RowStyle="{StaticResource EquipmentDataGridRowStyle}"
              CellStyle="{StaticResource EquipmentDataGridCellStyle}">

        <DataGrid.Columns>

            <DataGridTextColumn Header="Command Name" Width="120" Binding="{Binding CommandName}"/>
            <DataGridTextColumn Header="Command Code" Width="140" Binding="{Binding CommandCode}"/>
            <DataGridTextColumn Header="Address / Coil" Width="110" Binding="{Binding Address}"/>
            <DataGridTextColumn Header="Data Type" Width="90" Binding="{Binding DataType}"/>
            <DataGridTextColumn Header="Write Value" Width="100" Binding="{Binding WriteValue}"/>
            <DataGridTextColumn Header="Readback Address" Width="120" Binding="{Binding ReadbackAddress}"/>
            <DataGridTextColumn Header="Readback Value" Width="110" Binding="{Binding ReadbackValue}"/>
            <DataGridTextColumn Header="Category" Width="80" Binding="{Binding Category}"/>

            <DataGridCheckBoxColumn Header="Enabled"
                                    Width="70"
                                    Binding="{Binding Enabled}"/>

            <DataGridTextColumn Header="Description"
                                Width="*"
                                Binding="{Binding Description}"/>

        </DataGrid.Columns>

    </DataGrid>

</UserControl>