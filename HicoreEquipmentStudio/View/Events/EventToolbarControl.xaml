<UserControl x:Class="HicoreEquipmentStudio.View.Events.EventToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HicoreEquipmentStudio.Controls">

    <controls:CommonToolbarControl
        AddCommand="{Binding AddEventCommand}"
        EditCommand="{Binding EditEventCommand}"
        DeleteCommand="{Binding DeleteEventCommand}"
        ImportCommand="{Binding ImportEventCommand}"
        ExportCommand="{Binding ExportEventCommand}"
        ValidateCommand="{Binding ValidateEventCommand}" />

</UserControl>