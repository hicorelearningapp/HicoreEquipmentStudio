<UserControl x:Class="HiCore.EquipmentFramework.Config.View.Events.EventMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HiCore.EquipmentFramework.Config.View.Events">

    <Border BorderBrush="#D9D9D9"
            BorderThickness="1"
            Background="White">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="160"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FAFAFA"
                    BorderBrush="#E5E5E5"
                    BorderThickness="0,0,0,1">

                <TextBlock Text="Events"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#2F75B5"/>

            </Border>

            <local:EventToolbarControl Grid.Row="1"/>

            <local:EventGridControl Grid.Row="2"/>

            <Grid Grid.Row="3"
                  Margin="10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <local:EventDetailsControl Grid.Column="0"/>

                <local:EventPreviewControl Grid.Column="1"
                                           Margin="10,0,0,0"/>

            </Grid>

        </Grid>

    </Border>

</UserControl>