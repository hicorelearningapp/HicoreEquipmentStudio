<UserControl x:Class="HiCore.EquipmentFramework.Config.View.Mapping.SVIDMappingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="8">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <!-- ===================================================== -->
        <!-- LEFT MAIN SECTION -->
        <!-- ===================================================== -->

        <Border Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,8,8"
                BorderBrush="#D9D9D9"
                BorderThickness="1"
                Background="White">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Header -->

                <TextBlock Grid.Row="0"
                           Margin="10,8,0,6"
                           Text="SECS/GEM Mapping"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#2F75B5"/>

                <!-- Tabs -->

                <TabControl Grid.Row="1"
                            Margin="6,0,6,0"
                            SelectedIndex="{Binding SelectedTabIndex}">

                    <TabItem Header="SVID (Variables)"/>
                    <TabItem Header="ALID (Alarms)"/>
                    <TabItem Header="CEID (Events)"/>
                    <TabItem Header="RCMD (Commands)"/>
                    <TabItem Header="PPID (Recipes)"/>

                </TabControl>

                <!-- Dynamic Grid -->

                <ContentControl Grid.Row="2"
                                Margin="6,0,6,0"
                                Content="{Binding CurrentGridView}"/>

                <!-- Footer -->

                <TextBlock Grid.Row="3"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="{Binding TotalText}"/>

            </Grid>

        </Border>

        <!-- ===================================================== -->
        <!-- RIGHT DETAILS -->
        <!-- ===================================================== -->

        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="0,0,0,8"
                Padding="10"
                BorderBrush="#D9D9D9"
                BorderThickness="1"
                Background="White">

            <ContentControl Content="{Binding CurrentDetailsView}"/>

        </Border>

        <!-- ===================================================== -->
        <!-- BOTTOM SUMMARY -->
        <!-- ===================================================== -->

        <UniformGrid Grid.Row="1"
                     Grid.ColumnSpan="2"
                     Columns="5">

            <!-- Alarm -->

            <Border Margin="0,0,8,0"
                    BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    Background="White">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Margin="10,0"
                               VerticalAlignment="Center"
                               Text="ALID (Alarms)"
                               FontWeight="SemiBold"
                               Foreground="#2F75B5"/>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Alarms}"
                              Style="{StaticResource EquipmentDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
                              RowStyle="{StaticResource EquipmentDataGridRowStyle}"
                              CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ALID"
                                                Binding="{Binding ALID}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Alarm Name"
                                                Binding="{Binding AlarmName}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <Button Grid.Row="2"
                            Width="90"
                            Height="26"
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            Content="Open"/>

                </Grid>

            </Border>

            <!-- Events -->

            <Border Margin="0,0,8,0"
                    BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    Background="White">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Margin="10,0"
                               VerticalAlignment="Center"
                               Text="CEID (Events)"
                               FontWeight="SemiBold"
                               Foreground="#2F75B5"/>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Events}"
                              Style="{StaticResource EquipmentDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
                              RowStyle="{StaticResource EquipmentDataGridRowStyle}"
                              CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="CEID"
                                                Binding="{Binding CEID}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Event Name"
                                                Binding="{Binding EventName}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <Button Grid.Row="2"
                            Width="90"
                            Height="26"
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            Content="Open"/>

                </Grid>

            </Border>

            <!-- Commands -->

            <Border Margin="0,0,8,0"
                    BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    Background="White">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Margin="10,0"
                               VerticalAlignment="Center"
                               Text="RCMD (Commands)"
                               FontWeight="SemiBold"
                               Foreground="#2F75B5"/>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Commands}"
                              Style="{StaticResource EquipmentDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
                              RowStyle="{StaticResource EquipmentDataGridRowStyle}"
                              CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="RCMD"
                                                Binding="{Binding CommandCode}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Command Name"
                                                Binding="{Binding CommandName}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <Button Grid.Row="2"
                            Width="90"
                            Height="26"
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            Content="Open"/>

                </Grid>

            </Border>

            <!-- Recipes -->

            <Border Margin="0,0,8,0"
                    BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    Background="White">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Margin="10,0"
                               VerticalAlignment="Center"
                               Text="PPID (Recipes)"
                               FontWeight="SemiBold"
                               Foreground="#2F75B5"/>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Recipes}"
                              Style="{StaticResource EquipmentDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"
                              RowStyle="{StaticResource EquipmentDataGridRowStyle}"
                              CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="PPID"
                                                Binding="{Binding RecipeID}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Recipe Name"
                                                Binding="{Binding RecipeName}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <Button Grid.Row="2"
                            Width="90"
                            Height="26"
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            Content="Open"/>

                </Grid>

            </Border>

            <!-- Summary -->

            <Border BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    Background="White"
                    Padding="10">

                <StackPanel>

                    <TextBlock Text="Mapping Summary"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#2F75B5"
                               Margin="0,0,0,12"/>

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="SVID Mappings:"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding VariableCount}"
                                   Foreground="Green"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1"
                                   Text="ALID Mappings:"/>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding AlarmCount}"
                                   Foreground="Green"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2"
                                   Text="CEID Mappings:"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding EventCount}"
                                   Foreground="Green"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="3"
                                   Text="RCMD Mappings:"/>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding CommandCount}"
                                   Foreground="Green"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="4"
                                   Text="PPID Mappings:"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Text="{Binding RecipeCount}"
                                   Foreground="Green"
                                   FontWeight="SemiBold"/>

                        <Button Grid.Row="5"
                                Grid.ColumnSpan="2"
                                Height="28"
                                Margin="0,10,0,0"
                                Content="Validate All"/>

                    </Grid>

                </StackPanel>

            </Border>

        </UniformGrid>

    </Grid>

</UserControl>