<UserControl x:Class="HicoreEquipmentStudio.View.Mapping.MappingToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="#D9D9D9"
            BorderThickness="0,0,0,1"
            Background="White">

        <Grid Height="36">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="220"/>

            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Content="+ Add"/>

            <Border Grid.Column="1"
                    Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="2"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Content="✎ Edit"/>

            <Border Grid.Column="3"
                    Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="4"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Content="✕ Delete"/>

            <Border Grid.Column="5"
                    Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="6"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Content="⭳ Import"/>

            <Border Grid.Column="7"
                    Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="8"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Content="⭱ Export"/>

            <Border Grid.Column="9"
                    Style="{StaticResource ToolbarSeparatorStyle}"/>

            <Button Grid.Column="10"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Content="✔ Validate"/>

            <TextBox Grid.Column="12"
                     Margin="5,4"
                     Style="{StaticResource ToolbarSearchBoxStyle}"
                     Text="Search..."/>

        </Grid>

    </Border>

</UserControl>