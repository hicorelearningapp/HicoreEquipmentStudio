<UserControl x:Class="HiCore.EquipmentFramework.Config.View.Mapping.MappingCardsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- ===================================================== -->
        <!-- ALID -->
        <!-- ===================================================== -->

        <GroupBox Grid.Column="0"
                  Margin="0,0,6,0"
                  Header="ALID (Alarms)"
                  Style="{StaticResource DetailsGroupBoxStyle}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          Margin="4"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"

                          Style="{StaticResource EquipmentDataGridStyle}"

                          ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"

                          RowStyle="{StaticResource EquipmentDataGridRowStyle}"

                          CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ALID"
                                            Width="70"/>

                        <DataGridTextColumn Header="Alarm Name"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

                <TextBlock Grid.Row="1"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Text="Total: 5"/>

                <Button Grid.Row="2"
                        Width="90"
                        Height="28"
                        Margin="0,0,0,6"
                        HorizontalAlignment="Center"
                        Content="📂 Open"/>

            </Grid>

        </GroupBox>

        <!-- ===================================================== -->
        <!-- CEID -->
        <!-- ===================================================== -->

        <GroupBox Grid.Column="1"
                  Margin="0,0,6,0"
                  Header="CEID (Events)"
                  Style="{StaticResource DetailsGroupBoxStyle}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          Margin="4"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"

                          Style="{StaticResource EquipmentDataGridStyle}"

                          ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"

                          RowStyle="{StaticResource EquipmentDataGridRowStyle}"

                          CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="CEID"
                                            Width="70"/>

                        <DataGridTextColumn Header="Event Name"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

                <TextBlock Grid.Row="1"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Text="Total: 5"/>

                <Button Grid.Row="2"
                        Width="90"
                        Height="28"
                        Margin="0,0,0,6"
                        HorizontalAlignment="Center"
                        Content="📂 Open"/>

            </Grid>

        </GroupBox>

        <!-- ===================================================== -->
        <!-- RCMD -->
        <!-- ===================================================== -->

        <GroupBox Grid.Column="2"
                  Margin="0,0,6,0"
                  Header="RCMD (Commands)"
                  Style="{StaticResource DetailsGroupBoxStyle}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          Margin="4"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"

                          Style="{StaticResource EquipmentDataGridStyle}"

                          ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"

                          RowStyle="{StaticResource EquipmentDataGridRowStyle}"

                          CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="RCMD"
                                            Width="70"/>

                        <DataGridTextColumn Header="Command Name"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

                <TextBlock Grid.Row="1"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Text="Total: 5"/>

                <Button Grid.Row="2"
                        Width="90"
                        Height="28"
                        Margin="0,0,0,6"
                        HorizontalAlignment="Center"
                        Content="📂 Open"/>

            </Grid>

        </GroupBox>

        <!-- ===================================================== -->
        <!-- PPID -->
        <!-- ===================================================== -->

        <GroupBox Grid.Column="3"
                  Header="PPID (Recipes)"
                  Style="{StaticResource DetailsGroupBoxStyle}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          Margin="4"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"

                          Style="{StaticResource EquipmentDataGridStyle}"

                          ColumnHeaderStyle="{StaticResource EquipmentDataGridHeaderStyle}"

                          RowStyle="{StaticResource EquipmentDataGridRowStyle}"

                          CellStyle="{StaticResource EquipmentDataGridCellStyle}">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="PPID"
                                            Width="70"/>

                        <DataGridTextColumn Header="Recipe Name"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

                <TextBlock Grid.Row="1"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Text="Total: 5"/>

                <Button Grid.Row="2"
                        Width="90"
                        Height="28"
                        Margin="0,0,0,6"
                        HorizontalAlignment="Center"
                        Content="📂 Open"/>

            </Grid>

        </GroupBox>

    </Grid>

</UserControl>