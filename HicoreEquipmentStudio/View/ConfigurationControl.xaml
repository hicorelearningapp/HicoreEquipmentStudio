<UserControl x:Class="HicoreEquipmentStudio.View.ConfigurationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <Border BorderBrush="#D9D9D9"
            BorderThickness="1"
            CornerRadius="3"
            Background="White">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    BorderBrush="#E5E5E5"
                    BorderThickness="0,0,0,1"
                    Background="#FAFAFA">

                <TextBlock Text="Configuration"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#2F75B5"/>
            </Border>

            <!-- Menu -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- Equipment Info --><!--
                    <Button Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄"
                                       FontSize="14"
                                       Width="25"/>
                            <TextBlock Text="Equipment Info"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>-->

                    <!-- Selected Item -->
                    <Button Style="{StaticResource MenuButtonStyle}"
        Command="{Binding VariableCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗄" Width="25"/>
                            <TextBlock Text="Variables"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}"
        Command="{Binding AlarmCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" Width="25"/>
                            <TextBlock Text="Alarms"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}" Command="{Binding EventCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅"
                                       FontSize="14"
                                       Width="25"/>
                            <TextBlock Text="Events"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}" Command="{Binding CommandsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙"
                                       FontSize="14"
                                       Width="25"/>
                            <TextBlock Text="Commands"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}"
                        Command="{Binding RecipeCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋"
                                       FontSize="14"
                                       Width="25"/>
                            <TextBlock Text="Recipes"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding MappingCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗"
                                       FontSize="14"
                                       Width="25"/>
                            <TextBlock Text="SECS/GEM Mapping"/>
                        </StackPanel>
                    </Button>

                    <!--<Button Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍"
                                       FontSize="14"
                                       Width="25"/>
                            <TextBlock Text="Diagnostics"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📑"
                                       FontSize="14"
                                       Width="25"/>
                            <TextBlock Text="Summary"/>
                        </StackPanel>
                    </Button>-->

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Border>

</UserControl>