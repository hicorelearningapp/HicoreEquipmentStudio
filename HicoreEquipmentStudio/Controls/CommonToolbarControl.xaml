<UserControl x:Class="HiCore.EquipmentFramework.Config.Controls.CommonToolbarControl"
             x:Name="toolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <Border Background="White"
            BorderBrush="#D9D9D9"
            BorderThickness="0,0,0,1">

        <Grid Height="40">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Add -->

            <Button Grid.Column="0"
                    Command="{Binding AddCommand, ElementName=toolbar}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Width="90">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Image Source="/Images/add.png"
                           Width="16"
                           Height="16"
                           Margin="0,0,6,0"/>

                    <TextBlock Text="Add"
                               VerticalAlignment="Center"/>

                </StackPanel>

            </Button>


            <!-- Edit -->

            <Button Grid.Column="2"
                    Command="{Binding EditCommand, ElementName=toolbar}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Width="90">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Image Source="/Images/edit.png"
                           Width="16"
                           Height="16"
                           Margin="0,0,6,0"/>

                    <TextBlock Text="Edit"
                               VerticalAlignment="Center"/>

                </StackPanel>

            </Button>

            <!-- Delete -->

            <Button Grid.Column="4"
                    Command="{Binding DeleteCommand, ElementName=toolbar}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Width="90">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Image Source="/Images/delete.png"
                           Width="16"
                           Height="16"
                           Margin="0,0,6,0"/>

                    <TextBlock Text="Delete"
                               VerticalAlignment="Center"/>

                </StackPanel>

            </Button>

            <!--<Button Grid.Column="6"
        Command="{Binding ImportCommand, ElementName=toolbar}"
        Style="{StaticResource ToolbarButtonStyle}"
        Width="90">

                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/import.png"
               Width="16"
               Height="16"
               Margin="0,0,6,0"/>
                    <TextBlock Text="Import"/>
                </StackPanel>

            </Button>



            <Button Grid.Column="8"
        Command="{Binding ExportCommand, ElementName=toolbar}"
        Style="{StaticResource ToolbarButtonStyle}"
        Width="90">

                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/export.png"
               Width="16"
               Height="16"
               Margin="0,0,6,0"/>
                    <TextBlock Text="Export"/>
                </StackPanel>

            </Button>


            <Button Grid.Column="10"
        Command="{Binding ValidateCommand,
        ElementName=toolbar}"
        Style="{StaticResource ToolbarButtonStyle}"
        Width="90">

                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/validate.png"
               Width="16"
               Height="16"
               Margin="0,0,6,0"/>
                    <TextBlock Text="Validate"/>
                </StackPanel>

            </Button>-->
            <!-- Search -->

            <Grid Grid.Column="6"
                  Width="220"
                  Height="28"
                  Margin="0,5,10,5">

                <TextBox Style="{StaticResource ToolbarSearchBoxStyle}"
                         Text="{Binding SearchText,
                                        UpdateSourceTrigger=PropertyChanged}" />

            </Grid>

        </Grid>

    </Border>

</UserControl>